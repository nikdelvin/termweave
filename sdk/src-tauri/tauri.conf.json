{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Termweave",
  "version": "0.1.0",
  "identifier": "com.nikdelvin.termweave",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Termweave",
        "width": 1920,
        "height": 1080,
        "closable": true,
        "minimizable": true,
        "resizable": true,
        "maximizable": true,
        "fullscreen": true,
        "decorations": true,
        "center": true,
        "visible": false,
        "backgroundColor": "#010416"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:*; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/opentui-sidecar"]
  }
}
