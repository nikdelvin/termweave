{
  "name": "sidecar",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch --no-clear-screen src/index.tsx",
    "build": "bun scripts/build.ts",
    "build:dev-launcher": "bun scripts/build-dev-launcher.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src sdk scripts",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown ."
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  },
  "dependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@opentui/core": "0.4.5",
    "@opentui/solid": "0.4.5",
    "@solidjs/router": "0.16.2",
    "@termweave/sdk": "file:./sdk",
    "babel-preset-solid": "1.9.12",
    "solid-js": "1.9.12"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "@babel/preset-typescript": "7.29.7"
  },
  "patchedDependencies": {
    "@solidjs/router@0.16.2": "patches/@solidjs%2Frouter@0.16.2.patch"
  }
}
